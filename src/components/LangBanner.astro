---
import type { Locale } from '@i18n/index';
import { t, altLocale, localizedHref } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale).langSwitch;
const other = altLocale(locale);
const altHref = localizedHref(other);
---
<div class="alb-lang-banner" data-current-locale={locale} role="status" aria-live="polite">
  <span>{s.detectedBanner}</span>
  <a class="alb-lang-banner__action" href={altHref}>{s.detectedAction} →</a>
  <button type="button" class="alb-lang-banner__close" aria-label={s.dismiss}>×</button>
</div>
