---
/**
 * Albatroz planando — silhueta em fio (gullPath do deck da marca em
 * mira-animator), com batida de asa contida via CSS. Eco em army atrás,
 * traço laranja na frente.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---
<svg class:list={['alb-gull', className]} viewBox="0 0 140 44" width="120" height="38" fill="none" aria-hidden="true" focusable="false">
  <g class="alb-gull__echo">
    <path d="M 12 8 C 38.1 19.2, 60.7 22, 70 34 C 79.3 22, 101.9 19.2, 128 8" />
  </g>
  <g class="alb-gull__bird">
    <path class="alb-gull__wing alb-gull__wing--l" d="M 12 11 C 38.1 22.2, 60.7 25, 70 37" />
    <path class="alb-gull__wing alb-gull__wing--r" d="M 70 37 C 79.3 25, 101.9 22.2, 128 11" />
  </g>
</svg>
