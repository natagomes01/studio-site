---
import type { Locale } from '@i18n/index';
import { whatsappUrl } from '@i18n/index';

interface Props {
  locale: Locale;
  /** Page-specific WhatsApp message (e.g. so leads identify which page they came from). */
  waMessage?: string;
}

const { locale, waMessage } = Astro.props;
const href = whatsappUrl(locale, waMessage);
const label = locale === 'pt-br' ? 'Falar no WhatsApp' : 'Chat on WhatsApp';
---
<a
  class="alb-wa-fab"
  href={href}
  target="_blank"
  rel="noreferrer noopener"
  aria-label={label}
  title={label}
>
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false">
    <path fill="currentColor" d="M16.003 3.2c-7.07 0-12.8 5.73-12.8 12.8 0 2.26.6 4.47 1.74 6.42L3.2 28.8l6.55-1.7a12.78 12.78 0 0 0 6.25 1.6h.01c7.07 0 12.8-5.73 12.8-12.8 0-3.42-1.33-6.63-3.75-9.05a12.72 12.72 0 0 0-9.06-3.75Zm0 23.36h-.01a10.6 10.6 0 0 1-5.4-1.48l-.39-.23-3.88 1.01 1.04-3.79-.25-.4a10.6 10.6 0 0 1-1.63-5.67c0-5.86 4.77-10.63 10.63-10.63 2.84 0 5.5 1.11 7.51 3.12a10.55 10.55 0 0 1 3.12 7.52c0 5.86-4.77 10.63-10.64 10.63Zm5.83-7.95c-.32-.16-1.88-.93-2.17-1.04-.29-.11-.5-.16-.72.16-.21.32-.82 1.04-1.01 1.25-.19.21-.37.24-.69.08-.32-.16-1.34-.49-2.55-1.58-.94-.84-1.58-1.87-1.76-2.19-.18-.32-.02-.49.14-.65.15-.14.32-.37.48-.56.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.72-1.74-.99-2.38-.26-.62-.53-.54-.72-.55-.18-.01-.4-.01-.61-.01-.21 0-.56.08-.85.4-.29.32-1.11 1.09-1.11 2.65 0 1.57 1.14 3.08 1.3 3.29.16.21 2.24 3.42 5.43 4.79.76.33 1.35.52 1.81.67.76.24 1.45.21 2 .13.61-.09 1.88-.77 2.14-1.51.26-.74.26-1.37.18-1.51-.08-.13-.29-.21-.61-.37Z"/>
  </svg>
</a>

<style>
  .alb-wa-fab {
    position: fixed;
    right: 24px;
    bottom: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25D366;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22), 0 4px 10px rgba(0, 0, 0, 0.14);
    text-decoration: none;
    z-index: 1000;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }
  .alb-wa-fab:hover,
  .alb-wa-fab:focus-visible {
    transform: translateY(-2px);
    background: #20bd5a;
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.28), 0 6px 14px rgba(0, 0, 0, 0.18);
  }
  .alb-wa-fab:focus-visible {
    outline: 3px solid rgba(37, 211, 102, 0.45);
    outline-offset: 3px;
  }
  .alb-wa-fab:active {
    transform: translateY(0);
  }
  @media (max-width: 640px) {
    .alb-wa-fab {
      right: 16px;
      bottom: 16px;
      width: 52px;
      height: 52px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .alb-wa-fab { transition: none; }
    .alb-wa-fab:hover, .alb-wa-fab:focus-visible { transform: none; }
  }
</style>
